const DEFAULT_TIMEOUT_MS = 8000;

const SERVICES = Object.freeze([
  {
    id: 'elanvisual',
    name: 'ELANVISUAL',
    url: 'https://visual.elankav.com',
    category: 'Producción'
  },
  {
    id: 'elanpet',
    name: 'ELANPET',
    url: 'https://pet.elankav.com',
    category: 'Producción'
  },
  {
    id: 'elankav-core',
    name: 'ELANKAV CORE',
    url: 'https://elankav-core.vercel.app',
    category: 'Core / IA'
  },
  {
    id: 'elankav-platform',
    name: 'ELANKAV PLATFORM',
    url: 'https://elankav-platform.vercel.app',
    category: 'Plataforma'
  },
  {
    id: 'waha',
    name: 'WAHA',
    url: 'https://waha.elankav.com',
    category: 'Integración'
  },
  {
    id: 'orchestrator',
    name: 'ORCHESTRATOR',
    url: 'https://orchestrator.elankav.com/health',
    category: 'Centro de Control'
  }
]);

function nowMilliseconds() {
  return Number(process.hrtime.bigint() / 1000000n);
}

async function checkService(service, timeoutMs = DEFAULT_TIMEOUT_MS) {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), timeoutMs);
  const startedAt = nowMilliseconds();

  try {
    const response = await fetch(service.url, {
      method: 'GET',
      redirect: 'follow',
      signal: controller.signal,
      headers: {
        'User-Agent': 'ELANKAV-Orchestrator/0.4'
      }
    });

    const responseTimeMs = nowMilliseconds() - startedAt;

    return {
      ...service,
      online: true,
      status: 'online',
      http_status: response.status,
      response_time_ms: responseTimeMs,
      checked_at: new Date().toISOString()
    };
  } catch (error) {
    const responseTimeMs = nowMilliseconds() - startedAt;
    const timedOut = error?.name === 'AbortError';

    return {
      ...service,
      online: false,
      status: timedOut ? 'timeout' : 'offline',
      http_status: null,
      response_time_ms: responseTimeMs,
      error: timedOut
        ? `Tiempo de espera agotado después de ${timeoutMs} ms`
        : error.message,
      checked_at: new Date().toISOString()
    };
  } finally {
    clearTimeout(timeout);
  }
}

async function getEcosystemStatus() {
  const services = await Promise.all(
    SERVICES.map((service) => checkService(service))
  );

  const online = services.filter((service) => service.online).length;
  const offline = services.length - online;

  return {
    available: true,
    total: services.length,
    online,
    offline,
    healthy: offline === 0,
    services,
    checked_at: new Date().toISOString()
  };
}

module.exports = {
  getEcosystemStatus,
  checkService
};
